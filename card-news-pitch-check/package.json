{
  "name": "card-news-pitch-check",
  "version": "1.0.0",
  "description": "PitchCheck football story carousel automation",
  "main": "index.js",
  "scripts": {
    "collect:pitchcheck-local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pitchcheck/collect-local-media.ps1",
    "board:pitchcheck-local": "node scripts/pitchcheck/render-media-board.mjs",
    "assets:pitchcheck-plan": "node scripts/pitchcheck/resolve-story-assets.mjs samples/pitchcheck/lampard-fines-real-cta.json --write",
    "gemini:pitchcheck": "node scripts/pitchcheck/gemini-build-carousel.mjs --render --package --upload",
    "gemini:pitchcheck:dry": "node scripts/pitchcheck/gemini-build-carousel.mjs --no-gemini --render --package --upload",
    "images:pitchcheck-story-bank": "node scripts/pitchcheck/fetch-story-bank-images.mjs samples/pitchcheck/viral-story-bank-60.json --download --resume --queries-per-topic 3 --per-query 8 --download-count 3 --delay-ms 1200",
    "media:pitchcheck-diverse": "node scripts/pitchcheck/apply-diverse-media.mjs samples/pitchcheck/lampard-fines-real-cta.json --write",
    "package:pitchcheck-upload": "node scripts/pitchcheck/prepare-upload-package.mjs",
    "upload:pitchcheck": "node scripts/pitchcheck/upload-package.mjs",
    "render:pitchcheck": "node scripts/pitchcheck/render-carousel.mjs",
    "sample:pitchcheck": "node scripts/pitchcheck/render-carousel.mjs samples/pitchcheck/lampard-fines.json",
    "sample:pitchcheck-real-cta": "node scripts/pitchcheck/render-carousel.mjs samples/pitchcheck/lampard-fines-real-cta.json",
    "test": "node scripts/pitchcheck/render-carousel.mjs samples/pitchcheck/lampard-fines.json --dry-run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "puppeteer": "^25.3.0"
  }
}
