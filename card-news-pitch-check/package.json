{
  "name": "card-news-pitch-check",
  "version": "1.0.0",
  "description": "PitchCheck football story carousel automation",
  "main": "index.js",
  "scripts": {
    "collect:pitchcheck-local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pitchcheck/collect-local-media.ps1",
    "board:pitchcheck-local": "node scripts/pitchcheck/render-media-board.mjs",
    "bank:pitchcheck-real-stories": "node scripts/pitchcheck/generate-real-player-story-bank.mjs",
    "bank:pitchcheck-global-legend": "node scripts/pitchcheck/build-global-legend-bank.mjs",
    "assets:pitchcheck-plan": "node scripts/pitchcheck/resolve-story-assets.mjs samples/pitchcheck/lampard-fines-real-cta.json --write",
    "gemini:pitchcheck": "node scripts/pitchcheck/gemini-build-carousel.mjs --render --package --upload",
    "gemini:pitchcheck:dry": "node scripts/pitchcheck/gemini-build-carousel.mjs --no-gemini --render --package --upload",
    "images:pitchcheck-story-bank": "node scripts/pitchcheck/fetch-story-bank-images.mjs samples/pitchcheck/real-player-story-bank-60.json --download --resume --queries-per-topic 3 --per-query 8 --download-count 3 --delay-ms 1200",
    "media:pitchcheck-diverse": "node scripts/pitchcheck/apply-diverse-media.mjs samples/pitchcheck/lampard-fines-real-cta.json --write",
    "package:pitchcheck-upload": "node scripts/pitchcheck/prepare-upload-package.mjs",
    "upload:pitchcheck": "node scripts/pitchcheck/upload-package.mjs",
    "render:pitchcheck": "node scripts/pitchcheck/render-carousel.mjs",
    "sample:pitchcheck": "node scripts/pitchcheck/render-carousel.mjs samples/pitchcheck/lampard-fines.json",
    "sample:pitchcheck-real-cta": "node scripts/pitchcheck/render-carousel.mjs samples/pitchcheck/lampard-fines-real-cta.json",
    "test:pitchcheck-topical": "node scripts/pitchcheck/test-topical-golden-set.mjs && node scripts/pitchcheck/test-topical-render-inputs.mjs",
    "media:pitchcheck-topical:prepare": "node scripts/pitchcheck/prepare-topical-media-candidates.mjs",
    "media:pitchcheck-topical:extract": "node scripts/pitchcheck/extract-topical-curated-media.mjs",
    "render:pitchcheck-topical": "node scripts/pitchcheck/render-topical-golden-set.mjs --strict-media",
    "audit:pitchcheck-topical": "node scripts/pitchcheck/audit-topical-golden-set.mjs",
    "check:pitchcheck-topical": "npm run test:pitchcheck-topical && npm run render:pitchcheck-topical && npm run audit:pitchcheck-topical",
    "bank:pitchcheck-complete-170": "node scripts/pitchcheck/build-complete-story-bank-170.mjs",
    "media:pitchcheck-complete-170": "node scripts/pitchcheck/prepare-complete-media-170.mjs --strict",
    "research:pitchcheck-identity-media-170": "node scripts/pitchcheck/research-identity-verified-media-170.mjs --concurrency 6",
    "render:pitchcheck-complete-170": "node scripts/pitchcheck/render-topical-golden-set.mjs --bank samples/pitchcheck/complete-story-bank-170.json --media assets/reference/web/complete-media-170.json --output projects/complete-story-bank-170 --strict-media",
    "audit:pitchcheck-complete-170": "node scripts/pitchcheck/audit-complete-170.mjs",
    "prepare:pitchcheck-social": "node scripts/pitchcheck/prepare-social-publishing.mjs",
    "audit:pitchcheck-social": "node scripts/pitchcheck/audit-social-publish-queue.mjs",
    "auth:pitchcheck-social": "node scripts/pitchcheck/pitchcheck-meta-auth.mjs",
    "publish:pitchcheck-social": "node scripts/pitchcheck/run-social-publisher.mjs",
    "check:pitchcheck-complete-170": "npm run bank:pitchcheck-complete-170 && node scripts/pitchcheck/test-complete-170.mjs && npm run media:pitchcheck-complete-170 && npm run render:pitchcheck-complete-170 && npm run audit:pitchcheck-complete-170",
    "test": "node scripts/pitchcheck/test-real-player-story-bank.mjs && node scripts/pitchcheck/test-asia-story-batch.mjs && node scripts/pitchcheck/render-carousel.mjs samples/pitchcheck/lampard-fines.json --dry-run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "puppeteer": "^25.3.0",
    "sharp": "^0.34.3"
  }
}
